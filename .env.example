# fake-ollama configuration via environment variables.
#
# As of v0.7+, the recommended way to configure fake-ollama is the JSON file
# `config.json` (see `config.json.example`). All values below are optional
# and, when set, *override* values from the JSON file. Environment variables
# are best for secrets and per-deployment tweaks.

# ---- Path to the JSON config (default: ./config.json) ---------------------
# FAKE_OLLAMA_CONFIG=./config.json

# ---- Single-upstream legacy / quick-start ---------------------------------
# Setting both of these creates (or overrides) an upstream named "default"
# in addition to whatever the JSON file declares. This is the easiest way
# to keep your API key out of `config.json`.
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_AUTH_TOKEN=sk-replace-me
# FAKE_OLLAMA_MODELS=deepseek-chat,deepseek-reasoner
# FAKE_OLLAMA_MODEL_MAP={"deepseek-chat": "deepseek-chat"}

# ---- Scalar overrides -----------------------------------------------------
# FAKE_OLLAMA_HOST=127.0.0.1
# FAKE_OLLAMA_PORT=21434
# FAKE_OLLAMA_ADVERTISED_VERSION=0.6.4
# FAKE_OLLAMA_DEFAULT_MAX_TOKENS=4096
# FAKE_OLLAMA_TIMEOUT=300
# FAKE_OLLAMA_USE_SYSTEM_PROXY=false
# FAKE_OLLAMA_ENFORCE_CONTEXT_LIMIT=true

# ---- Model profiles (JSON, overrides the JSON file's section) ------------
# FAKE_OLLAMA_MODEL_PROFILES={"deepseek-chat":{"capabilities":["completion","tools"],"context_length":65536}}
