# Upstream Anthropic-compatible API
ANTHROPIC_BASE_URL=http://8.166.137.143:48085
ANTHROPIC_AUTH_TOKEN=sk-replace-me

# Local Ollama-compatible server
FAKE_OLLAMA_HOST=127.0.0.1
# Use a non-default port to avoid conflicting with a real local Ollama (11434)
FAKE_OLLAMA_PORT=21434

# Version string reported by GET /api/version. Some Ollama clients reject
# servers older than a minimum version (e.g. "0.6.4 or higher").
FAKE_OLLAMA_ADVERTISED_VERSION=0.6.4

# Default max_tokens passed to Anthropic when client does not specify
FAKE_OLLAMA_DEFAULT_MAX_TOKENS=4096

# Comma-separated list of model names to advertise via /api/tags.
# Names are passed through to the upstream as-is unless overridden by
# FAKE_OLLAMA_MODEL_MAP (JSON map of ollama_name -> upstream_name).
FAKE_OLLAMA_MODELS=claude-3-5-sonnet-20241022,claude-3-5-haiku-20241022,claude-3-opus-20240229
# FAKE_OLLAMA_MODEL_MAP={"claude-sonnet": "claude-3-5-sonnet-20241022"}

# Per-model profile (JSON object). For each Ollama-style model name you can
# declare:
#   - capabilities: ["completion", "tools", "vision"] (subset shown in
#                   GitHub Copilot / other clients' model picker)
#   - context_length: maximum total tokens (input + output) the model can
#                     handle. Used both for display *and* as a guardrail to
#                     reject oversized requests (see
#                     FAKE_OLLAMA_ENFORCE_CONTEXT_LIMIT).
#   - max_output_tokens: cap on max_tokens / num_predict for this model.
#   - thinking: "auto" (default) | "enabled" | "disabled". When set to
#               "enabled" the upstream payload gets
#               thinking: {type:"enabled", budget_tokens:N} injected so
#               reasoning models (DeepSeek-V3.2, Claude 3.7+) actually
#               produce a thinking block. "disabled" forces it off.
#   - thinking_budget_tokens: budget when thinking=enabled (default 1024;
#                             DeepSeek ignores this, Anthropic honours it).
#   - show_thinking: bool, default true. When true the upstream `thinking`
#                    block is surfaced to clients wrapped as
#                    <think>...</think> (works in Open WebUI / Cherry
#                    Studio / etc.) and also as message.thinking (Ollama)
#                    or reasoning_content delta (OpenAI).
# Models not listed here fall back to capabilities=[completion,tools,vision]
# and context_length=200000 with thinking=auto.
# FAKE_OLLAMA_MODEL_PROFILES={"claude-3-5-sonnet-20241022":{"capabilities":["completion","tools","vision"],"context_length":200000,"max_output_tokens":8192},"deepseek-v4-pro":{"capabilities":["completion","tools"],"context_length":128000,"max_output_tokens":8192,"thinking":"enabled","thinking_budget_tokens":1024,"show_thinking":true},"deepseek-v4-flash":{"capabilities":["completion"],"context_length":64000}}

# When true (default), reject requests whose estimated input + max_tokens
# exceed the target model's context_length. Cheap insurance against runaway
# bills from accidentally huge prompts. Set to false to disable.
FAKE_OLLAMA_ENFORCE_CONTEXT_LIMIT=true

# Request timeout in seconds for upstream calls
FAKE_OLLAMA_TIMEOUT=300

# When false (default), the upstream HTTP client ignores HTTP_PROXY /
# HTTPS_PROXY / Windows system proxy settings. Set to true if your upstream
# is only reachable through your system proxy (e.g. Clash, V2Ray).
FAKE_OLLAMA_USE_SYSTEM_PROXY=false
